# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Redsys (TPV)
REDSYS_MERCHANT_CODE=your_merchant_code
REDSYS_TERMINAL=001
REDSYS_SECRET_KEY=your_redsys_secret_key
NEXT_PUBLIC_REDSYS_MERCHANT_CODE=your_merchant_code

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# OpenAI (para generación de contenido)
OPENAI_API_KEY=your_openai_api_key
# Modelos IA opcionales
# BLOG_COVER_TEXT_MODEL=gpt-5.4
# BLOG_COVER_IMAGE_MODEL=gpt-image-2
# Calidad WebP al publicar portadas IA (1-100, por defecto 85)
# BLOG_COVER_WEBP_QUALITY=85
# Usar imagenes de referencia de vehiculo (images/IA_blog/ + rutas fijas). false para desactivar
# BLOG_COVER_USE_VEHICLE_REFERENCES=true
# OPENAI_MAILING_MODEL=gpt-5.4
# OPENAI_SALE_LOCATION_MODEL=gpt-5.4

# Calendar Subscription Token (para sincronización de calendario)
# Este token protege el endpoint de suscripción al calendario
# Cambia este valor por un token seguro y compártelo solo con tu equipo
CALENDAR_SUBSCRIPTION_TOKEN=furgocasa2026
NEXT_PUBLIC_CALENDAR_TOKEN=furgocasa2026

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
